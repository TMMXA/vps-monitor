AKILE_CLIENT_ID=replace-me
AKILE_SECRET=replace-me
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_IDS=123456789
# Aliases are also supported:
# TG_TOKEN=replace-me
# CHAT_ID=123456789
# TELEGRAM_PROXY=http://proxy-host:proxy-port
ADMIN_TOKEN=replace-me
SERVER_IDS=12345,67890
COLLECT_INTERVAL_MINUTES=30
REPORT_TIME=09:00
TZ=Asia/Hong_Kong
RETENTION_DAYS=90
DATABASE_PATH=/data/vps-monitor.sqlite3
# Prefer TELEGRAM_PROXY if only Telegram needs a proxy.
THRESHOLD_12345_GIB_PER_HOUR=15
THRESHOLD_67890_GIB_PER_HOUR=1
